{
  "$schema": "https://json.schemastore.org/web-manifest.json",
  "id": "/?utm_source=pwa",
  "name": "মাই অ্যাপ - সম্পূর্ণ ডিজিটাল প্ল্যাটফর্ম",
  "short_name": "মাই অ্যাপ",
  "description": "সেরা ফিচার ও অফলাইন সাপোর্ট সহ আধুনিক প্রোগ্রেসিভ ওয়েব অ্যাপ।",
  "lang": "bn",
  "dir": "ltr",
  "start_url": "/?utm_source=pwa&utm_medium=homescreen",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "orientation": "any",
  "background_color": "#ffffff",
  "theme_color": "#008080",
  "categories": [
    "utilities",
    "productivity",
    "lifestyle"
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.myapp",
      "id": "com.example.myapp"
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/maskable-icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/maskable-icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/monochrome-icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "monochrome"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/desktop-1.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "ডেস্কটপ হোম পেজ"
    },
    {
      "src": "/screenshots/mobile-1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "মোবাইল অ্যাপ ভিউ"
    }
  ],
  "shortcuts": [
    {
      "name": "নতুন তৈরি করুন",
      "short_name": "তৈরি",
      "description": "এক ক্লিকে নতুন কন্টেন্ট তৈরি করুন",
      "url": "/create?utm_source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-create.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "অনুসন্ধান",
      "short_name": "সার্চ",
      "description": "অ্যাপের ভেতরের যেকোনো কিছু খুঁজুন",
      "url": "/search?utm_source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-search.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "photos",
          "accept": ["image/jpeg", "image/png", "image/webp"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+myapp",
      "url": "/handle-protocol?type=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "text/plain": [".txt"],
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    {
      "origin": "https://app.yourdomain.com"
    }
  ],
  "widgets": [
    {
      "name": "ডেইলি সামারি উইজেট",
      "short_name": "উইজেট",
      "description": "হোম স্ক্রিনে দৈনিক আপডেট দেখুন",
      "tag": "daily-summary",
      "template": "widget-template",
      "ms_ac_template": "/widgets/summary.json",
      "data": "/widgets/data.json",
      "type": "text/html",
      "icons": [
        {
          "src": "/icons/widget-icon.png",
          "sizes": "128x128",
          "type": "image/png"
        }
      ]
    }
  ]
}
